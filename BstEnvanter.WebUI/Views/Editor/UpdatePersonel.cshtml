@model BstEnvanter.WebUI.Models.UpdatePersonelViewModel
@{
    ViewData["Title"] = "UpdatePersonel";
    Layout = "~/Views/_Layout.cshtml";
}

<div class="container-fluid">
        <div class="jumbotron jumbotron-fluid">
        <h1 class="display-4">Update a Personel</h1>
        <hr />
    </div>
    <form method="post" asp-action="updatepersonel" class="col-md-8">
        <div class="form-group">
            <input asp-for="personel.name" class="form-control" type="text" placeholder="Name" />
            <span asp-validation-for="personel.name"></span>
        </div>
        <div class="form-group">
            <input asp-for="personel.surname" class="form-control" type="text" placeholder="Surname" />
            <span asp-validation-for="personel.surname"></span>
        </div>
        <div class="form-group">
            <input asp-for="personel.age" value="@Model.personel.age" class="form-control" type="text" placeholder="Age" />
            <span asp-validation-for="personel.age"></span>
        </div>
        <div class="form-group">
            <select asp-for="personel.sexId" class="form-control" asp-items="@(new SelectList(Model.sex,"id","name"))"></select>
        </div>
        <div class="form-group">
            <select asp-for="personel.departmentId" class="form-control" asp-items="@(new SelectList(Model.department,"id","name"))"></select>
        </div>

        <div class="form-group">
            <input asp-for="personel.roomNo" class="form-control" type="text" placeholder="Room No" />
            <span asp-validation-for="personel.roomNo"></span>
        </div>

        <div class="mt-1 text-end">
            <input type="hidden" asp-for="personel.id" />
            <button class="btn btn-primary col-md-2">Update</button>
            <a asp-action="listofpersonel" class="btn btn-info col-md-2">Back</a>
        </div>
    </form>
</div>